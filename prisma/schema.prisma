generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Gig {
  id                 String       @id
  freelancerId       String
  title              String
  category           String
  description        String
  budget             Float
  deadline           DateTime
  skills             String       @default("[]")
  deliverables       String
  status             String       @default("open")
  contractAddress    String?
  createdAt          DateTime     @default(now())
  ethAmount          Float?
  clientArgument     String?
  freelancerArgument String?
  mediatorReasoning  String?
  mediatorVerdict    String?
  aiReviewData       String?
  User               User         @relation(fields: [freelancerId], references: [id])
  Request            Request[]
  Submission         Submission[]
}

model Request {
  id               String   @id
  gigId            String
  clientId         String
  proposal         String
  proposedTimeline String
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  contractAddress  String?
  ethAmount        Float?
  User             User     @relation(fields: [clientId], references: [id])
  Gig              Gig      @relation(fields: [gigId], references: [id])
}

model Submission {
  id           String   @id
  gigId        String
  freelancerId String
  textContent  String?
  url          String?
  filePaths    String   @default("[]")
  notes        String?
  createdAt    DateTime @default(now())
  version      Int      @default(1)
  User         User     @relation(fields: [freelancerId], references: [id])
  Gig          Gig      @relation(fields: [gigId], references: [id])
}

model User {
  id                String       @id
  name              String
  email             String       @unique
  password          String
  role              String       @default("freelancer")
  walletAddress     String?
  createdAt         DateTime     @default(now())
  bio               String?
  education         String       @default("[]")
  industry          String?
  professionalTitle String?
  profilePicture    String?
  skills            String       @default("[]")
  workExperience    String       @default("[]")
  Gig               Gig[]
  Request           Request[]
  Submission        Submission[]
}
