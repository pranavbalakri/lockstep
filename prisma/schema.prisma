generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role          String   @default("freelancer")
  walletAddress String?
  createdAt     DateTime @default(now())

  gigs        Gig[]        @relation("FreelancerGigs")
  requests    Request[]    @relation("ClientRequests")
  submissions Submission[] @relation("FreelancerSubmissions")
}

model Gig {
  id           String   @id @default(cuid())
  freelancerId String
  title        String
  category     String
  description  String
  budget       Float
  deadline     DateTime
  skills       String   @default("[]")
  deliverables String
  status          String   @default("open")
  ethAmount          Float?
  contractAddress    String?
  clientArgument     String?
  freelancerArgument String?
  mediatorVerdict    String?
  mediatorReasoning  String?
  createdAt          DateTime @default(now())

  freelancer User         @relation("FreelancerGigs", fields: [freelancerId], references: [id])
  requests   Request[]
  submission Submission?
}

model Request {
  id               String   @id @default(cuid())
  gigId            String
  clientId         String
  proposal         String
  proposedTimeline String
  status           String   @default("pending")
  contractAddress  String?
  ethAmount        Float?
  createdAt        DateTime @default(now())

  gig    Gig  @relation(fields: [gigId], references: [id])
  client User @relation("ClientRequests", fields: [clientId], references: [id])
}

model Submission {
  id           String   @id @default(cuid())
  gigId        String   @unique
  freelancerId String
  textContent  String?
  url          String?
  filePaths    String   @default("[]")
  notes        String?
  createdAt    DateTime @default(now())

  gig        Gig  @relation(fields: [gigId], references: [id])
  freelancer User @relation("FreelancerSubmissions", fields: [freelancerId], references: [id])
}
